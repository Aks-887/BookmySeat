# Example environment variables - DO NOT commit real secrets
# Copy this file to .env and fill in real values in deployment

# Email / SMTP configuration
DEFAULT_FROM_EMAIL=noreply@bookmyseat.example
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=you@example.com
EMAIL_HOST_PASSWORD=super-secret-password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_TIMEOUT=10
# Required for the optional delivery-event monitoring endpoint.
EMAIL_EVENTS_WEBHOOK_SECRET=replace-with-a-long-random-webhook-secret
# Optional: set EMAIL_BACKEND for transactional providers, e.g. 'anymail'
# EMAIL_BACKEND=anymail.backends.sendgrid.EmailBackend

# Django / payment configuration (keep real values only in your deployment secret store)
DJANGO_SECRET_KEY=replace-with-a-long-random-value
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=bookmyseat.example
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
PAYMENT_CURRENCY=INR
TICKET_PRICE=200.00
PAYMENT_GATEWAY_TIMEOUT=10

# Database (optional)
# DATABASE_URL=sqlite:///db.sqlite3

# SendGrid (recommended):
# Set one of these to enable SendGrid via django-anymail
SENDGRID_API_KEY=your-sendgrid-api-key

# Or AWS SES (alternative):
# AWS_SES_ACCESS_KEY_ID=your-aws-access-key
# AWS_SES_SECRET_ACCESS_KEY=your-aws-secret
# AWS_SES_REGION_NAME=us-east-1

# Optionally override backend explicitly
# EMAIL_BACKEND=anymail.backends.sendgrid.EmailBackend
