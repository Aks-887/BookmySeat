# Example EnvironmentFile for systemd (do NOT store secrets in repo)
# Copy to /etc/bookmyseat/env and secure with root-only permissions
# Example variables required by the Django app and worker
SECRET_KEY=replace-with-secure-secret
DEBUG=False
ALLOWED_HOSTS=your.domain.com
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/bookmyseat
DEFAULT_FROM_EMAIL=noreply@your.domain.com
# Providers (choose one)
# SENDGRID_API_KEY=your-sendgrid-key
# or
# AWS_SES_ACCESS_KEY_ID=your-aws-key
# AWS_SES_SECRET_ACCESS_KEY=your-aws-secret
# AWS_SES_REGION_NAME=us-east-1

EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=you@example.com
EMAIL_HOST_PASSWORD=super-secret
EMAIL_USE_TLS=True

RAZORPAY_KEY_ID=rzp_test_replace-with-key-id
RAZORPAY_KEY_SECRET=replace-with-razorpay-secret

# Optional overrides
# EMAIL_BACKEND=anymail.backends.sendgrid.EmailBackend
